library(ggplot2)
ana2CMTiv <- function(Dose,pars,t,dur){
  K10 <- pars['CL1']/pars['V1']
  K12 <- pars['CL2']/pars['V1']
  K21 <- pars['CL2']/pars['V2']
  A   <- K10 + K12 + K21
  L1  <- (A + sqrt(A * A - 4 * K10 * K21)) / 2
  L2  <- (A - sqrt(A * A - 4 * K10 * K21)) / 2
  C1  <- (K21 - L1) / (L2 - L1) / pars['V1']
  C2  <- (K21 - L2) / (L1 - L2) / pars['V1']

  ifelse(t <= dur,
    ((Dose/dur) * C1 / L1 * (1-exp(-L1 * t))) + ((Dose/dur) * C2 / L2 * (1-exp(-L2 * t))),
    ((Dose/dur) * C1 / L1 * (1-exp(-L1 * dur)) * exp(-L1 * (t-dur))) + ((Dose/dur) * C2 / L2 * (1-exp(-L2 * dur)) * exp(-L2 * (t-dur)))
  )

}
pars   <- c(CL1=10,V1=5,CL2=5,V2=100)
times  <- seq(0,24,length.out=200)
out    <- amp.sim::mdose(Dose=10,tau=24,ndose=1,t=times,func=ana2CMTiv,pars=pars,dur=2)
ggplot(out,aes(time,y)) + geom_line()
